# Python virtual environment
.venv/

# Python byte-code cache
__pycache__/
*.pyc
*.pyo

# pytest cache
.pytest_cache/

# Distribution / build artifacts
dist/
build/
*.egg-info/

# Editor / IDE artifacts
.vscode/
.idea/
*.swp
*.swo

# Frontend build artifacts
frontend/node_modules/
frontend/dist/
node_modules/
Makefile.local

# Generated panel bundle (built by `make build`; distributed via release archive)
custom_components/climate_manager/www/panel.js

# Generated use-case scenario data (built by `make use-case-data` from
# each <slug>/scenario.py; screenshots are the committed deliverable).
# Covers both the legacy single scenario.json and per-variant scenario.<id>.json.
docs/use-cases/*/scenario.json
docs/use-cases/*/scenario.*.json
